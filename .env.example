# Copy to .env for docker compose (optional — AI keys can also be set in the Streamlit UI)
APP_VERSION=2.0
JOB_DB_PATH=/app/data/jobs.db

# Gemini / OpenAI-compatible AI recommendations
AI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
AI_API_KEY=
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash

# Job ingestion API (optional)
JOB_API_KEY=https://www.arbeitnow.com/api/job-board-api
API_JOB_LIMIT=500
